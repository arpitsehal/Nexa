{
  "headers": [
    {
      "source": "/app-debug.apk",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"Nexa.apk\"" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!app-debug\\.apk).*)",
      "destination": "/index.html"
    }
  ]
}
